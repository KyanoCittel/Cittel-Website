Options -Indexes
RewriteEngine On

# Custom 404 pagina
ErrorDocument 404 /404.html

# Forceer HTTPS + www in één stap (vermijdt omleidingsketens)
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^cittel\.be$ [NC]
RewriteRule ^ https://www.cittel.be%{REQUEST_URI} [R=301,L]

# /index of /index.html → redirect naar / (root)
RewriteCond %{THE_REQUEST} /index(\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# Als iemand /page.html opent → redirect naar /page (301)
RewriteCond %{THE_REQUEST} /([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Intern: /page → /page.html laden (zonder redirect)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+)$ $1.html [L]

# ---------- Compressie ----------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml application/xml text/xml text/plain
</IfModule>

# ---------- Browser caching ----------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                          "access plus 1 month"

    # HTML — kort cachen zodat updates snel zichtbaar zijn
    ExpiresByType text/html                 "access plus 1 hour"

    # Afbeeldingen
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/gif                 "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"

    # CSS & JS
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType text/javascript           "access plus 1 year"

    # Fonts
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/ttf                  "access plus 1 year"
    ExpiresByType application/font-woff2    "access plus 1 year"
    ExpiresByType application/font-woff     "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Statische assets: 1 jaar, immutable
    <FilesMatch "\.(webp|png|jpe?g|gif|svg|ico|css|js|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # HTML: 1 uur, moet gerevalideerd worden
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
</IfModule>
